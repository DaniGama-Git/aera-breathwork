{
  "manifest_version": 3,
  "name": "āera — Breathwork for Performance",
  "version": "3.6.0",
  "description": "Calendar-triggered breathwork sessions to sharpen focus before key moments",
  "permissions": ["alarms", "storage", "notifications", "scripting", "activeTab", "tabs"],
  "host_permissions": ["https://calendar.google.com/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon-48.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["defaults.json", "audio/*", "popup.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
